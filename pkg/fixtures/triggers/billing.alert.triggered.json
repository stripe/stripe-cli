{
  "_meta": {
    "template_version": 0
  },
  "fixtures": [
    {
      "name": "billing_meter",
      "path": "/v1/billing/meters",
      "method": "post",
      "params": {
        "display_name": "Stripe CLI Billing Meter",
        "event_name": "stripe_cli_alert_trigger_event",
        "default_aggregation": {
          "formula": "sum"
        }
      }
    },
    {
      "name": "billing_alert",
      "path": "/v1/billing/alerts",
      "method": "post",
      "params": {
        "alert_type": "usage_threshold",
        "title": "Usage Alert (created by Stripe CLI)",
        "usage_threshold_config": {
          "gte": 100,
          "meter": "${billing_meter:id}",
          "recurrence": "one_time"
        }
      }
    },
    {
      "name": "billing_meter_event_session",
      "path": "/v2/billing/meter_event_session",
      "method": "post",
      "headers": {
        "Content-Type": "application/json",
        "Stripe-Version": "2024-09-30.acacia"
      },
      "params": {}
    },
    {
      "name": "create_billing_meter_event_stream",
      "path": "/v2/billing/meter_event_stream",
      "method": "post",
      "api_base": "https://meter-events.stripe.com",
      "headers": {
        "Content-Type": "application/json",
        "Stripe-Version": "2024-09-30.acacia",
        "Authorization": "Bearer ${billing_meter_event_session:authentication_token}"
      },
      "params": {
        "events": [
          {
            "event_name": "stripe_cli_alert_trigger_event",
            "timestamp": "${time-now-RFC3339}",
            "identifier": "${generate-uuid}",
            "payload": {
              "value": "150"
            }
          }
        ]
      }
    }
  ]
}
