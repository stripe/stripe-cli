diff --git a/client_test.go b/client_test.go
--- a/client_test.go
+++ b/client_test.go
@@ -185,6 +185,29 @@
 	assertLines(t, logger.errorLogs, 0)
 }
 
+func TestClient_longStdoutLine(t *testing.T) {
+	t.Parallel()
+
+	process := helperProcess("stdout-long-line")
+	logger := &trackingLogger{Logger: hclog.Default()}
+	c := NewClient(&ClientConfig{
+		Cmd:                    process,
+		HandshakeConfig:        testHandshake,
+		Plugins:                testPluginMap,
+		Logger:                 logger,
+		PluginStdoutBufferSize: 128 * 1024,
+	})
+	defer c.Kill()
+
+	if _, err := c.Start(); err != nil {
+		t.Fatalf("err should be nil, got %s", err)
+	}
+
+	time.Sleep(100 * time.Millisecond)
+
+	assertLines(t, logger.errorLogs, 0)
+}
+
 type delayedStdoutCmdRunner struct {
 	*cmdrunner.CmdRunner
 }
